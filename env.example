KOMARI_BASE_URL=https://your-komari.example
TELEGRAM_BOT_TOKEN=123456:YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=123456789

# Telegram 允许接收命令的 chat（可选，逗号分隔；默认仅 TELEGRAM_CHAT_ID）
TELEGRAM_ALLOWED_CHAT_IDS=

# Telegram 管理员 chat（可选，逗号分隔；默认仅 TELEGRAM_CHAT_ID）
TELEGRAM_ADMIN_CHAT_IDS=

# AI（可选，启用 /ask 与 /ai）
AI_API_BASE=
AI_API_KEY=
AI_MODEL=

# 启动通知（可选）
# BOT_START_NOTIFY=0 可关闭启动消息
BOT_START_NOTIFY=1

# 启动通知里显示的实例名（可选，建议填机器名/环境名）
BOT_INSTANCE_NAME=

# Komari API 超时（秒）
KOMARI_TIMEOUT_SECONDS=15

# Komari API 鉴权（可选）
KOMARI_API_TOKEN=
KOMARI_API_TOKEN_HEADER=Authorization
KOMARI_API_TOKEN_PREFIX=Bearer

# Komari 节点并发请求数
KOMARI_FETCH_WORKERS=6

# 容器内数据目录（固定）
DATA_DIR=/data

# 统计时区（默认 Asia/Shanghai）
STAT_TZ=Asia/Shanghai

# AI模型配置（可选）
AI_API_BASE=
AI_API_KEY=
AI_MODEL=

# 下面这些如果你旧环境变量里没配，会用脚本默认值；你也可以按需改
TOP_N=3
SAMPLE_INTERVAL_SECONDS=300
SAMPLE_RETENTION_HOURS=720
HISTORY_HOT_DAYS=60
HISTORY_RETENTION_DAYS=365

# 日志
LOG_LEVEL=INFO
LOG_FILE=
